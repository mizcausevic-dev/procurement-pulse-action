  },
  "keywords": [
    "github-action",
    "actions",
    "kinetic-gain",
    "kinetic-gain-suite",
    "ai-governance",
    "well-known",
    "disclosure",
    "vendor-self-score",
    "procurement-pulse",
    "typescript"
  ],
  "engines": {
